# Copy this file to .env.local and fill in the values from your
# Supabase project (Project Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: enables an email alert to you whenever someone reports a post.
# Leave these unset and the site works fine, just without that email.
RESEND_API_KEY=your-resend-api-key
ADMIN_NOTIFICATION_EMAIL=you@example.com
# Your live site's URL, used to build links inside the notification email.
NEXT_PUBLIC_SITE_URL=https://azande-news.vercel.app
